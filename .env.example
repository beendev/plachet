# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
# Public URL exposed to frontend for generating share links.
# Example: VITE_PUBLIC_APP_URL="https://app.plachet.be"
VITE_PUBLIC_APP_URL=""
# Optional override for address autocomplete provider.
VITE_NOMINATIM_SEARCH_URL="https://nominatim.openstreetmap.org/search"
# Brand website used in email footer (defaults to APP_URL).
MARKETING_WEBSITE_URL="https://plachet.be"

# Security: keep source export disabled in production.
EXPORT_CODE_ENABLED="false"
# Optional token required when export is enabled.
EXPORT_CODE_TOKEN=""

# Auth/session hardening
SESSION_SECRET="change-me-in-production"
AUTH_REQUIRED="false"

# CORS hardening
# Example: CORS_ALLOWED_ORIGINS="https://app.plachet.be,https://admin.plachet.be"
CORS_ALLOWED_ORIGINS=""
# In production set to true when allowlist is ready.
CORS_STRICT="false"

# API rate limiting
RATE_LIMIT_WINDOW_MS="300000"
RATE_LIMIT_MAX="300"
AUTH_RATE_LIMIT_WINDOW_MS="900000"
AUTH_RATE_LIMIT_MAX="20"

# Block disposable email domains (comma-separated, optional)
BLOCKED_EMAIL_DOMAINS=""

# RESEND_API_KEY: Optional for transactional emails.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"

# Local fallback only when Supabase is not configured.

# Supabase primary database settings.
# When SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are set, the app uses Supabase as the main database.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional legacy sync from local SQLite to Supabase during migration.
SUPABASE_SYNC_ENABLED="false"
