APP_URL="https://staging.plachet.be"
NODE_ENV="production"

SUPABASE_URL="https://your-staging-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-staging-service-role-key"
SUPABASE_SYNC_ENABLED="false"

RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"

SESSION_SECRET="change-me-with-a-long-random-secret"
AUTH_REQUIRED="true"

CORS_STRICT="true"
CORS_ALLOWED_ORIGINS="https://staging.plachet.be"

RATE_LIMIT_WINDOW_MS="300000"
RATE_LIMIT_MAX="300"
AUTH_RATE_LIMIT_WINDOW_MS="900000"
AUTH_RATE_LIMIT_MAX="20"

BLOCKED_EMAIL_DOMAINS="mailinator.com,yopmail.com,10minutemail.com,tempmail.com"

EXPORT_CODE_ENABLED="false"
EXPORT_CODE_TOKEN=""

